{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://rdmmesh.bank/schema/api/items-page.json",
  "title": "ItemsPage",
  "description": "Paginated page of CodeItem rows for a given version (or, on /rdm/.../items, for a resolved as_of pair).",
  "type": "object",
  "javaType": "bank.rdmmesh.spec.api.ItemsPage",
  "required": ["page_info", "items"],
  "properties": {
    "page_info": { "$ref": "../common/types.json#/definitions/page_info" },
    "items": {
      "type": "array",
      "items": { "$ref": "../entity/code-item.json" }
    },
    "version": { "$ref": "../common/types.json#/definitions/semver" },
    "effective_at": { "$ref": "../common/types.json#/definitions/business_date" },
    "knowledge_at": { "$ref": "../common/types.json#/definitions/instant" }
  },
  "additionalProperties": false
}
