{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://rdmmesh.bank/schema/events/workflow-transition-event.json",
  "title": "WorkflowTransitionEvent",
  "description": "In-process event emitted by the workflow module on every successful state transition. Consumed by audit and (when applicable) publishing.",
  "type": "object",
  "javaType": "bank.rdmmesh.spec.events.WorkflowTransitionEvent",
  "required": ["event_id", "version_id", "from", "to", "actor", "occurred_at"],
  "properties": {
    "event_id": { "$ref": "../common/types.json#/definitions/uuid" },
    "version_id": { "$ref": "../common/types.json#/definitions/uuid" },
    "codeset_id": { "$ref": "../common/types.json#/definitions/uuid" },
    "domain_id": { "$ref": "../common/types.json#/definitions/uuid" },
    "from": { "$ref": "../common/enums.json#/definitions/version_status" },
    "to": { "$ref": "../common/enums.json#/definitions/version_status" },
    "action": { "$ref": "../common/enums.json#/definitions/transition_action" },
    "actor": { "$ref": "../common/types.json#/definitions/om_user_id" },
    "comment": { "type": "string" },
    "occurred_at": { "$ref": "../common/types.json#/definitions/instant" }
  },
  "additionalProperties": false
}
