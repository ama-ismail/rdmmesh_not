{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://rdmmesh.bank/schema/entity/code-set.json",
  "title": "CodeSet",
  "description": "A business reference data set (e.g., country_iso, ifrs9_stages, position_system_matrix). The CodeSet itself stores only metadata; items live in CodeSetVersion.items. See SPEC §3.4.",
  "type": "object",
  "javaType": "bank.rdmmesh.spec.entity.CodeSet",
  "required": [
    "id",
    "domain_id",
    "name",
    "key_spec",
    "hierarchy_mode"
  ],
  "properties": {
    "id": { "$ref": "../common/types.json#/definitions/uuid" },
    "domain_id": { "$ref": "../common/types.json#/definitions/uuid" },
    "name": {
      "$ref": "../common/types.json#/definitions/qualified_name",
      "description": "Stable machine name within the domain. Forms the OM FQN 'rdmmesh.<domain>.<codeset>'."
    },
    "display_name": { "type": "string", "maxLength": 256 },
    "description": { "type": "string" },
    "labels": { "$ref": "../common/types.json#/definitions/localized_label" },
    "tags": {
      "type": "array",
      "items": { "$ref": "../common/types.json#/definitions/tag" }
    },
    "key_spec": { "$ref": "key-spec.json" },
    "hierarchy_mode": { "$ref": "../common/enums.json#/definitions/hierarchy_mode" },
    "release_channels": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "../common/enums.json#/definitions/release_channel" },
      "default": ["PROD"]
    },
    "current_published_version": {
      "$ref": "../common/types.json#/definitions/semver",
      "description": "Cached pointer to the latest PUBLISHED version. NULL until first publish."
    },
    "schema_version": {
      "type": "integer",
      "minimum": 1,
      "description": "Active CodeSetSchema.version pointer."
    },
    "created_at": { "$ref": "../common/types.json#/definitions/instant" },
    "created_by": { "$ref": "../common/types.json#/definitions/om_user_id" },
    "updated_at": { "$ref": "../common/types.json#/definitions/instant" }
  },
  "additionalProperties": false
}
