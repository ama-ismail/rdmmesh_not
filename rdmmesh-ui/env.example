# Скопируй в .env.local (имя `.env.local` — стандартный для Vite, gitignored).
# Все значения собраны из docker/docker-compose.yml dev-стека.

# OIDC issuer и client (см. docker/keycloak/realms/realm-bank.json)
VITE_OIDC_AUTHORITY=http://localhost:8090/realms/bank
VITE_OIDC_CLIENT_ID=rdmmesh-ui

# Куда обращаться API-клиенту. В dev — пустая строка означает "тот же origin",
# что вместе с Vite-proxy /api -> http://localhost:8080 даёт корректный CORS-free flow.
VITE_API_BASE=

# (Только dev) куда vite-proxy перенаправляет /api/*
VITE_DEV_API_TARGET=http://localhost:8080
